# RT-Electricity-Forecast Environment Configuration
# Copy this file to .env and customize as needed.
# All variables are prefixed with RTEF_ (see config/settings.py).

# Data
RTEF_DATA_PATH=data/pjm_hourly_est.csv
RTEF_TRAIN_RATIO=0.80

# Model
RTEF_MODEL_TYPE=lightgbm
RTEF_MODEL_PATH=artifacts/model.lgb
RTEF_N_ESTIMATORS=2000
RTEF_LEARNING_RATE=0.05
RTEF_NUM_LEAVES=127
RTEF_EARLY_STOPPING_ROUNDS=50

# Pricing
RTEF_PRICE_INTERCEPT=15.0
RTEF_PRICE_LINEAR_COEFF=0.005
RTEF_PRICE_QUADRATIC_COEFF=0.000002
RTEF_PRICE_NOISE_STD=2.0

# Streaming
RTEF_TOKEN_BUCKET_CAPACITY=10
RTEF_TOKEN_BUCKET_REFILL_RATE=5.0
RTEF_QUEUE_MAX_SIZE=100

# API
RTEF_API_HOST=0.0.0.0
RTEF_API_PORT=8000
RTEF_DASHBOARD_PORT=8501
